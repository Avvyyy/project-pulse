# ── App ──────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_SECRET_KEY=change-me-in-production-min-32-chars

# ── PostgreSQL ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse_secret
POSTGRES_DB=pulse_db
POSTGRES_SSLMODE=disable

# ── Redis ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Kafka ─────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=pulse-consumer-group

# ── JWT ───────────────────────────────────────────
JWT_ACCESS_SECRET=access-secret-change-in-prod
JWT_REFRESH_SECRET=refresh-secret-change-in-prod
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ── CORS ──────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
