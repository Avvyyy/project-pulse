# ─────────────────────────────────────────────────────────────────────────────
# Project Pulse — environment configuration
#
# Copy to .env and fill in real values before running any service.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_PORT=8080

# REQUIRED in production — must not be the placeholder value below.
# Generate: openssl rand -hex 32
ADMIN_SECRET=admin-secret-change-in-production

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse_secret    # change in production
POSTGRES_DB=pulse_db

# Prisma reads DATABASE_URL directly.
DATABASE_URL=postgresql://pulse:pulse_secret@localhost:5432/pulse_db?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                   # set a strong password in production
REDIS_DB=0

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_EVENTS=pulse_events

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT_PER_MINUTE=1000   # per API key

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000
